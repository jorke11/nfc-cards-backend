# Environment
NODE_ENV=development
PORT=4000

# Database Configuration
DATABASE_HOST=your-remote-db-host
DATABASE_PORT=5432
DATABASE_USER=your-db-user
DATABASE_PASSWORD=your-db-password
DATABASE_NAME=nfc_profiles

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION=7d

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
S3_BUCKET_NAME=your-s3-bucket-name

# Gmail Configuration (for email sending)
GMAIL_USER=your-gmail@gmail.com
GMAIL_PASSWORD=your-gmail-app-password

# Frontend URL (for redirects and CORS)
FRONTEND_URL=http://localhost:3000

# OAuth Providers - Google
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:4000/auth/google/callback

# OAuth Providers - Facebook
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret
FACEBOOK_CALLBACK_URL=http://localhost:4000/auth/facebook/callback

# OAuth Providers - LinkedIn
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
LINKEDIN_CALLBACK_URL=http://localhost:4000/auth/linkedin/callback

# OAuth Providers - Apple
APPLE_CLIENT_ID=your-apple-client-id
APPLE_TEAM_ID=your-apple-team-id
APPLE_KEY_ID=your-apple-key-id
APPLE_PRIVATE_KEY=your-apple-private-key-path-or-content
APPLE_CALLBACK_URL=http://localhost:4000/auth/apple/callback

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=10
